# Server Configuration
PORT=3000

# Security Configuration
# Generate a strong secret key for signing JWTs (e.g., node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=replace_this_with_a_long_random_hex_string_in_production

# Admin Credentials
ADMIN_USERNAME=tyson

# Hashed password using bcryptjs. Default hash for "abhinav10" (which you can change)
